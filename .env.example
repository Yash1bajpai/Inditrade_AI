# ==============================================================================
# IndiTrade AI - Environment Configuration Example
# Copy this file to .env and fill in your actual API keys and credentials.
# NEVER commit .env to version control!
# ==============================================================================

# --- Application & Environment Settings ---
APP_NAME=IndiTrade_AI
APP_ENV=development           # development | staging | production
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
TIMEZONE=Asia/Kolkata

# --- UN Comtrade API ---
COMTRADE_API_KEY=your_comtrade_api_key_here

# --- LLM & AI Models (Groq / HuggingFace) ---
GROQ_API_KEY=your_groq_api_key_here
HF_TOKEN=your_hf_token_here

# --- Vector Database (Qdrant) ---
QDRANT_URL=your_qdrant_url_here
QDRANT_API_KEY=your_qdrant_api_key_here

# --- Database & Backend (Supabase) ---
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here