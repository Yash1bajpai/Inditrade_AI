# ==========================================
# IndiTrade AI — Environment Variables
# ==========================================
# Copy this file to .env and fill in your free tier keys.
# NEVER commit .env to GitHub!

# 1. UN Comtrade API (Free Tier: 500 calls/day, 100K records/call)
# Get free key from: https://comtradeplus.un.org/
COMTRADE_API_KEY="your_comtrade_free_api_key_here"

# 2. Groq API (Free Tier: 20 req/min, used for RAG generation & synthetic Q&A)
# Get free key from: https://console.groq.com/
GROQ_API_KEY="your_groq_free_api_key_here"

# 3. Qdrant Cloud Vector DB (Free Tier: 4GB cluster)
# Get free cluster from: https://cloud.qdrant.io/
QDRANT_URL="https://your-cluster-id.us-east-1-0.aws.cloud.qdrant.io:6333"
QDRANT_API_KEY="your_qdrant_api_key_here"

# 4. Supabase Relational DB (Free Tier: 500MB, used for query/prediction logs)
# Get free project from: https://supabase.com/
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="your_supabase_anon_key_here"

# 5. HuggingFace Hub (For pushing fine-tuned Llama-3.2-1B QLoRA model)
# Get write token from: https://huggingface.co/settings/tokens
HF_TOKEN="your_huggingface_write_token_here"
